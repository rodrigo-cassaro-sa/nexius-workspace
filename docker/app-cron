# Workspace S&A - tarefas agendadas (cron). Formato /etc/cron.d (tem o campo de usuario: root).
# As variaveis de ambiente (DB_*, RESEND_*, etc.) chegam ao cron via /etc/environment,
# gravado no start do container (ver CMD do Dockerfile). php CLI: /usr/local/bin/php.
# min hora dia mes diasem  usuario  comando

# Fila de e-mail: envia os e-mails pendentes a cada 5 minutos.
*/5 * * * * root /usr/local/bin/php /var/www/html/cron/processar-fila-email.php >> /var/www/html/logs/cron.log 2>&1

# Retencao de logs: remove registros com mais de 1 ano, todo dia as 03:30.
30 3 * * * root /usr/local/bin/php /var/www/html/cron/limpar-logs.php >> /var/www/html/logs/cron.log 2>&1

# Digest semanal: resumo por e-mail toda segunda-feira as 08:00.
0 8 * * 1 root /usr/local/bin/php /var/www/html/cron/enviar-digest.php >> /var/www/html/logs/cron.log 2>&1
